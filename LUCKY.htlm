<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Lucky Chest - ZAARD Arcade</title>
    <style>
        body { margin: 0; background: #020006; color: white; font-family: 'Arial', sans-serif; overflow: hidden; }
        .ui-panel { 
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; 
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            background: rgba(0,0,0,0.9);
        }
        .banner { 
            width: 90%; max-width: 600px; height: 300px; 
            background-size: cover; background-position: center;
            border-radius: 30px; margin-bottom: 20px;
        }
        button { background: linear-gradient(to right, #5a2d82, #9d4edd); color: white; border: none; padding: 15px 30px; border-radius: 25px; cursor: pointer; margin: 10px; font-weight: bold; }
        .chest-grid { display: flex; gap: 20px; }
        .chest { font-size: 80px; cursor: pointer; padding: 20px; border: 2px solid #5a2d82; border-radius: 20px; }
    </style>
</head>
<body>

    <div id="ui-container" class="ui-panel">
        <div id="pantalla-inicio" class="banner" style="background-image: url('https://ipfs.io/ipfs/bafybeieymfqhcj6pj2zvclkoecftyx4gzpkzcnohxwhyzytyijqqyjgzei')"></div>
        <button onclick="document.getElementById('pantalla-inicio').style.display='none'; document.getElementById('menu-seleccion').style.display='flex';">¡ENTRAR AL JUEGO!</button>
    </div>

    <div id="menu-seleccion" class="ui-panel" style="display:none;">
        <h2 style="color:#bc8fef;">LUCKY CHEST</h2>
        <div class="chest-grid">
            <div class="chest" onclick="jugar(1)">📦</div>
            <div class="chest" onclick="jugar(2)">📦</div>
            <div class="chest" onclick="jugar(3)">📦</div>
        </div>
        <button onclick="conectarBilletera()">CONECTAR BILLETERA</button>
        <button onclick="window.location.href='index.html'">VOLVER AL MENÚ</button>
    </div>

    <script>
        // Tus CIDs organizados como en tu juego de memoria
        const cids = [
            "bafybeihg4evetf2c5fqeozxttct7mone4jaequysqrxndlx4wqmf2zn45a",
            "bafkreicdxf34fpb4t5yx6p4ijurnspvv47rgu373nl5yeyzj57s3ignoli",
            "bafybeift764exak3gtcylewcd5mufkfaxabusywobwg2z5mcfkp7qeaapy",
            "bafybeib5xg3hrhliizyw7n65reashvsqf6ritx7oi5334rbcvync27hbwe",
            "bafybeiafcclndycyvb5p62jjhnypzezaa2fxw2oqmlt5azvual334lgd6y"
        ];
        
        const BURN_ADDR = "0x000000000000000000000000000000000000dEaD";
        const BACKGROUND_IMG = "https://ipfs.io/ipfs/bafybeiga7wy2ef4hstm5ppwfw36rvxipb3wzu3tm7ac6dfbwhmvnoqyc3u";

        // Aplicar fondo espacial
        document.body.style.backgroundImage = "url('" + BACKGROUND_IMG + "')";

        async function conectarBilletera() {
            if (window.ethereum) {
                try {
                    await window.ethereum.request({ method: 'eth_requestAccounts' });
                    alert("Billetera Conectada.");
                } catch (e) { alert("Conexión necesaria."); }
            } else { alert("Instala MetaMask."); }
        }

        function jugar(id) {
            const gano = Math.random() > 0.5;
            if(gano) {
                alert("¡Ganaste! Tu premio se enviará a tu wallet.");
            } else {
                alert("Cofre vacío. Fondos enviados a la quema: " + BURN_ADDR);
            }
        }
    </script>
</body>
</html>
